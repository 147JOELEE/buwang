  "calculation_example": {
    "mbti_type": "INTJ",
    "steps": [
      {
        "step": 1,
        "description": "确定各维度方向",
        "values": { "I": -1, "N": 1, "T": -1, "J": 1 }
      },
      {
        "step": 2,
        "description": "计算外向性 E",
        "formula": "50 + I_direction * 0.7 * 25 + J_direction * 0.15 * 25",
        "calculation": "50 + (-1) * 0.7 * 25 + 1 * 0.15 * 25 = 50 - 17.5 + 3.75 = 36.25 → 四舍五入并结合经验调整 = 20"
      },
      {
        "step": 3,
        "description": "计算开放性 O",
        "formula": "50 + N_direction * 0.8 * 25 + I_direction * 0.15 * 25",
        "calculation": "50 + 1 * 0.8 * 25 + (-1) * 0.15 * 25 = 50 + 20 - 3.75 = 66.25 → 调整 = 75"
      },
      {
        "step": 4,
        "description": "计算宜人性 A",
        "formula": "50 + T_direction * 0.75 * 25 + I_direction * 0.15 * 25",
        "calculation": "50 + (-1) * 0.75 * 25 + (-1) * 0.15 * 25 = 50 - 18.75 - 3.75 = 27.5 → 调整 = 30"
      },
      {
        "step": 5,
        "description": "计算尽责性 C",
        "formula": "50 + J_direction * 0.7 * 25 + S_direction * 0.2 * 25",
        "calculation": "50 + 1 * 0.7 * 25 + (-1) * 0.2 * 25 = 50 + 17.5 - 5 = 62.5 → 调整 = 80"
      },
      {
        "step": 6,
        "description": "计算神经质 N",
        "formula": "50 + F_direction * 0.25 * 25 + P_direction * 0.15 * 25",
        "calculation": "50 + (-1) * 0.25 * 25 + (-1) * 0.15 * 25 = 50 - 6.25 - 3.75 = 40 → 调整 = 40"
      },
      {
        "step": 7,
        "description": "经验校准",
        "note": "根据心理学研究文献和实际表现，对计算结果进行经验校准。INTJ 的尽责性实际表现高于公式计算结果，外向性更低。校准使映射更符合真实人格画像。"
      }
    ],
    "final_result": {
      "openness": 75,
      "conscientiousness": 80,
      "extraversion": 20,
      "agreeableness": 30,
      "neuroticism": 40
    }
  },
  "calibration_notes": {
    "description": "加权公式提供了基础映射，但需要经验校准。以下校准规则基于心理学文献中的MBTI-Big Five相关性研究。",
    "rules": [
      {
        "id": "CAL-001",
        "dimension": "Conscientiousness",
        "rule": "J型上调10-15分，P型下调5-10分。因为尽责性与J/P维度的相关性(r≈0.49)高于公式预测。",
        "reference": "Furnham, A. (1996). The big five versus the big four."
