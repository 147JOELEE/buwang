{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MBTI to Big Five Mapping",
  "version": "1.0.0",
  "description": "16种MBTI类型到Big Five人格参数的映射表，包含典型得分区间和加权逻辑",
  "mapping_algorithm": {
    "name": "加权维度映射法 (Weighted Dimension Mapping)",
    "version": "1.0.0",
    "description": "将MBTI四个维度(I/E, S/N, T/F, J/P)分别映射到Big Five五个维度，使用加权公式计算最终得分",
    "dimension_mapping": {
      "EI_to_Extraversion": {
        "description": "MBTI的E/I维度主要映射到Big Five的外向性(E)，同时影响开放性(O)和宜人性(A)",
        "primary_mapping": "Extraversion",
        "primary_weight": 0.7,
        "secondary_mappings": [
          { "target": "Openness", "weight": 0.15, "direction": "E_positive" },
          { "target": "Agreeableness", "weight": 0.15, "direction": "E_positive" }
        ]
      },
      "SN_to_Openness": {
        "description": "MBTI的S/N维度主要映射到Big Five的开放性(O)，同时影响尽责性(C)",
        "primary_mapping": "Openness",
        "primary_weight": 0.8,
        "secondary_mappings": [
          { "target": "Conscientiousness", "weight": 0.2, "direction": "S_positive" }
        ]
      },
      "TF_to_Agreeableness": {
        "description": "MBTI的T/F维度主要映射到Big Five的宜人性(A)，同时影响神经质(N)",
        "primary_mapping": "Agreeableness",
        "primary_weight": 0.75,
        "secondary_mappings": [
          { "target": "Neuroticism", "weight": 0.25, "direction": "F_positive" }
        ]
      },
      "JP_to_Conscientiousness": {
        "description": "MBTI的J/P维度主要映射到Big Five的尽责性(C)，同时影响神经质(N)和外向性(E)",
        "primary_mapping": "Conscientiousness",
        "primary_weight": 0.7,
        "secondary_mappings": [
          { "target": "Neuroticism", "weight": 0.15, "direction": "P_positive" },
          { "target": "Extraversion", "weight": 0.15, "direction": "J_positive" }
        ]
      }
    },
    "scoring_formula": {
      "description": "对每个MBTI维度，根据偏好方向(E/I等)计算该维度对各Big Five维度的贡献值，然后加总",
      "formula": "BigFive[d] = base_50 + sum_over_MBTI_dims(mbti_dim.direction * mbti_dim.mapping[d].weight * range_25)",
      "parameters": {
        "base_50": "基准分50分，保证所有类型在0-100范围内",
        "range_25": "每个MBTI维度的影响力为±25分，保证总分在合理范围",
        "direction": "E=+1, I=-1; N=+1, S=-1; F=+1, T=-1; J=+1, P=-1"
      }
    }
  },
